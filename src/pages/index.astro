---
// usb.plan.ai — landing page. Aesthetic: phosphor-green CRT / TTY terminal
// "boot into the product" (adapted from temp/ Terminal-Boot design system).
// Tokens: bg #06090a, green #4dffa0, accents cyan/violet/amber, ink #d6e4dc.
// Fonts: JetBrains Mono (terminal) + Space Grotesk (display).
// Signature: an animated boot log + typed shell prompt; sections render as
// shell output ($ cmd). CRT scanlines/glow/flicker — all gated by
// prefers-reduced-motion. AA-contrast body text. Self-contained: scoped CSS +
// minimal inline JS (scroll reveal). Docs at /docs.
const repo = 'https://github.com/planailabs/usb.plan.ai';

const boot = [
	['0.00', 'init council kernel', 'OK'],
	['0.18', 'mount /dev/usb (exFAT)', 'OK'],
	['0.37', 'verify model-pack sha256', 'OK'],
	['0.61', 'llama-server :8080 — local', 'OK'],
	['0.94', 'role-council: solver skeptic security chair', 'OK'],
	['1.22', 'whisper.cpp · vision (vlm)', 'OK'],
	['1.40', 'network probe', 'NONE'],
	['1.41', 'privacy-guard: air-gapped', 'HELD'],
];

const seats = [
	{ name: 'Claude Opus 4.8', role: 'reasoning', house: 'anthropic' },
	{ name: 'GPT-5.5', role: 'allround', house: 'openai' },
	{ name: 'Gemini 3.1 Pro', role: 'long-ctx · chair', house: 'google' },
	{ name: 'DeepSeek V4', role: 'cost · frontier', house: 'deepseek' },
	{ name: 'DeepSeek-R1-Distill 32B', role: 'local · MIT', house: 'on-device' },
	{ name: 'Qwen3-32B', role: 'local agent · apache-2', house: 'on-device' },
];

const features = [
	{ k: 'local_chat', d: 'Fast single-model answers — the default.', tag: 'offline' },
	{ k: 'council', d: 'Solve → skeptic → synthesis, with the trace.', tag: 'offline' },
	{ k: 'trace', d: 'Every opinion, the ranking, the dissent.', tag: 'offline' },
	{ k: 'voice_stt', d: 'Push-to-talk, on-device whisper.cpp.', tag: 'offline' },
	{ k: 'vision_vlm', d: 'Read images & documents locally.', tag: 'offline' },
	{ k: 'phone_access', d: '2nd screen on LAN — TLS + one-time token.', tag: 'offline' },
	{ k: 'byo_keys', d: 'Passphrase-encrypted in the vault.', tag: 'online' },
	{ k: 'privacy_diff', d: 'See what is sent, to whom, at what cost.', tag: 'online' },
];

const playbooks = [
	{ k: 'code-review', d: 'Run a risky diff past the Skeptic before it ships.' },
	{ k: 'incident', d: 'Triage logs off-grid; get ranked next steps.' },
	{ k: 'field-notes', d: 'Dictate, summarize, structure with no signal.' },
	{ k: 'doc-triage', d: 'Read a stack of PDFs locally; surface what matters.' },
];

const personas = [
	{ t: 'privacy developer', d: 'Review code, logs, architecture locally. Escalate online only when you choose to.' },
	{ t: 'field researcher · journalist', d: 'Process sensitive notes, photos, documents on the move, under changing connectivity.' },
	{ t: 'security · compliance', d: 'Traceable model opinions, minimal-trace, bring-your-own keys.' },
];

const editions = [
	{ n: 'pocket', tagline: 'runs almost anywhere', m: ['1× 4–8B model', 'role council', 'whisper-base'], req: '8–12 GB RAM · CPU ok', star: false },
	{ n: 'field', tagline: 'documents & notes, offline', m: ['8B model', 'vision (vlm)', 'voice'], req: '12–16 GB RAM · GPU rec.', star: false },
	{ n: 'lab', tagline: 'the real multi-model council', m: ['32B reason + 32B agent', '8B + vision', 'deep deliberation'], req: '48–64 GB RAM · GPU · NVMe', star: true },
];

const faqs = [
	{ q: 'Does it really work fully offline?', a: 'Yes — that’s the default. Online is opt-in only and gated by a Privacy-Diff. Nothing leaves the stick without your explicit consent.' },
	{ q: 'Is there a subscription?', a: 'No. Free and open-source (Apache-2.0). Bring your own API keys if you ever want to escalate online.' },
	{ q: 'What hardware do I need?', a: 'Pocket runs on a normal laptop (8–12 GB RAM, CPU ok). The multi-model Lab tier wants 48–64 GB RAM, a GPU, and an NVMe USB-SSD.' },
	{ q: 'Council vs a single model — when does it win?', a: '“Review this code / decision / risk and show me the dissent.” For “write me an email,” a single model is fine. The edge is measured in evals, not asserted.' },
	{ q: 'Is it “zero trace”?', a: 'No — minimal-trace, honestly. No persistent user data on the host, but unavoidable OS artifacts exist and are documented. A compromised host is out of scope.' },
];

const compare = [
	['', 'portablemind', 'techjarves', 'usb.plan.ai'],
	['license', 'closed', 'MIT', 'Apache-2.0'],
	['core', 'single-model', 'single-model', 'auditable council'],
	['council', '—', '—', 'opinion · review · chair'],
	['online (opt-in)', '—', '—', 'frontier + privacy-diff'],
	['engine', 'proprietary', 'ollama', 'llama.cpp llama-server'],
	['price', '$49–$129', 'free', 'free (oss)'],
];

const sections = {
	how: 'cat how-it-works.md',
	vs: 'diff cloud offline',
	routing: './privacy-guard --status',
	seats: 'ls council/seats',
	features: 'systemctl status app',
	playbooks: 'ls playbooks/',
	editions: './preflight --tiers',
	who: 'whoami',
	compare: 'column -t compare.tsv',
	faq: 'man faq',
	proof: 'git log --oneline council',
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>usb.plan.ai — Portable AI Council</title>
		<meta name="description" content="An open-source, offline-first, auditable AI Council on a USB stick. Boot your council. No cloud required." />
		<link rel="canonical" href="https://usb.plan.ai/" />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://usb.plan.ai/" />
		<meta property="og:site_name" content="usb.plan.ai" />
		<meta property="og:title" content="usb.plan.ai — Portable AI Council" />
		<meta property="og:description" content="Boot your council. Offline-first, auditable, open-source. No cloud required. (v0.2 concept — building in public.)" />
		<meta property="og:image" content="https://usb.plan.ai/og.png" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="usb.plan.ai — Portable AI Council" />
		<meta name="twitter:description" content="Bring the best models you trust into one auditable council — offline-first. v0.2 concept." />
		<meta name="twitter:image" content="https://usb.plan.ai/og.png" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<div class="scanlines" aria-hidden="true"></div>
		<div class="vignette" aria-hidden="true"></div>

		<header class="nav">
			<a class="brand" href="/"><span class="dot" aria-hidden="true"></span>usb.plan.ai</a>
			<nav class="nav-links" aria-label="Primary">
				<a href="#how">how</a>
				<a href="#vs">cloud_vs_offline</a>
				<a href="#editions">editions</a>
				<a href="/docs/">docs</a>
				<a class="ghost" href={repo}>github ★</a>
			</nav>
		</header>

		<a class="concept-banner" href="/docs/project/roadmap/">
			<b>v0.2 concept</b> — site &amp; docs exist; the product (engine, council, evals) isn’t built yet. building in public → roadmap
		</a>

		<main>
			<!-- HERO: CRT terminal boot -->
			<section class="hero">
				<div class="crt">
					<div class="crt-bar">
						<span class="dots" aria-hidden="true"><i></i><i></i><i></i></span>
						<span class="crt-title">usb.plan.ai — tty1</span>
						<span class="crt-stat"><span class="led" aria-hidden="true"></span> offline</span>
					</div>
					<div class="crt-screen">
						<ol class="boot" aria-label="Boot log">
							{boot.map((b, i) => (
								<li class="boot-line" style={`--i:${i}`}>
									<span class="t">[{b[0]}]</span>
									<span class="msg">{b[1]}</span>
									<span class="dotfill" aria-hidden="true"></span>
									<span class={`stamp ${b[2] === 'OK' ? 'ok' : b[2] === 'HELD' ? 'held' : 'none'}`}>[ {b[2]} ]</span>
								</li>
							))}
						</ol>

						<div class="hero-head">
							<p class="kicker">// portable ai council · grid-down ready</p>
							<h1>Boot your<br /><span class="accent">council.</span></h1>
							<p class="tagline">Offline-first AI on a USB stick — voice, vision, chat, and an <em>auditable council</em> of the models you trust. No login. No subscription. No telemetry.</p>
						</div>

						<div class="prompt">
							<span class="ps1">council@usb:~$</span>
							<span class="typed">council "review this risky bash script offline"</span>
							<span class="cursor" aria-hidden="true"></span>
						</div>

						<div class="cta-row">
							<a class="btn primary" href={repo}>$ build --free</a>
							<a class="btn" href="#how">$ man how-it-works</a>
						</div>
					</div>
				</div>
			</section>

			<!-- trust pillars -->
			<section class="pillars" aria-label="Why it's different">
				<div class="pillar"><span class="p-tag">[01] cloud</span><b>zero cloud dependency</b><p>Works when the internet doesn’t. No login, no account, no phone-home.</p></div>
				<div class="pillar"><span class="p-tag">[02] data</span><b>private by default</b><p>Nothing leaves the stick unless you say so. Keys &amp; chats in the vault.</p></div>
				<div class="pillar"><span class="p-tag">[03] reach</span><b>tri-platform + browser</b><p>Windows, macOS, Linux. Browser-only UI — nothing to install on the host.</p></div>
			</section>

			<!-- how -->
			<section class="band" id="how">
				<p class="cmd"><span class="ps1">council@usb:~$</span> {sections.how}</p>
				<h2>A council, not a single answer.</h2>
				<p class="lead">A good single model wins at "write me an email." A council wins at "review this decision, this code, this risk — and show me the dissent."</p>
				<div class="rows reveal">
					<div class="row"><span class="row-n">01</span><div><h3>first_opinions</h3><p>N seats answer in parallel — locally as roles, or as real frontier models.</p></div></div>
					<div class="row"><span class="row-n">02</span><div><h3>peer_review</h3><p>Each seat ranks the others' anonymized answers. Order randomized, no self-voting.</p></div></div>
					<div class="row"><span class="row-n">03</span><div><h3>chairman</h3><p>Synthesizes a reasoned final answer — plus the full, auditable trace.</p></div></div>
				</div>
			</section>

			<!-- trace dossier -->
			<section class="band" id="trace">
				<p class="cmd"><span class="ps1">council@usb:~$</span> cat ~/.council/trace.json</p>
				<figure class="dossier reveal" aria-label="Sample Council trace">
					<div class="dsr-meta">
						<span><b>prompt</b> “run this risky bash script offline”</span>
						<span><b>sha256</b> 9f3a1c7b…e10d</span>
						<span><b>engine</b> llama-server · role-council</span>
						<span class="ok"><b>mode</b> offline · verified</span>
					</div>
					<ol class="dsr-log">
						<li class="op solver"><span class="r">solver</span><span class="gl">›</span> run it with <code>sudo</code> to skip the permission errors.</li>
						<li class="op risk"><span class="r">skeptic</span><span class="gl">!</span> <code>sudo</code> + unverified script = full-system exposure.</li>
						<li class="op risk"><span class="r">security</span><span class="gl">!</span> no checksum, no sandbox. block as-is.</li>
					</ol>
					<div class="dsr-rank"><span class="r">review</span> skeptic ranked highest · accuracy &amp; insight <span class="muted">(anonymized, no self-vote)</span></div>
					<div class="dsr-verdict"><span class="r">chairman</span><span class="gl">=</span> don’t <code>sudo</code> it. dry-run in a sandbox, verify the checksum, run as your user. dissent on <code>sudo</code> was decisive.</div>
				</figure>
			</section>

			<!-- cloud vs offline -->
			<section class="band" id="vs">
				<p class="cmd"><span class="ps1">council@usb:~$</span> {sections.vs}</p>
				<h2>When the grid goes down, your chatbot dies. Your council doesn’t.</h2>
				<div class="versus reveal">
					<div class="vs-col cloud">
						<div class="vs-head">- cloud chatbot</div>
						<ul>
							<li>needs a login &amp; a connection</li>
							<li>uploads your data to a server</li>
							<li>one model, one opinion</li>
							<li>dies when the grid goes down</li>
							<li>subscription, forever</li>
						</ul>
					</div>
					<div class="vs-col ours">
						<div class="vs-head">+ usb.plan.ai</div>
						<ul>
							<li>runs from the stick, air-gapped</li>
							<li>data stays local — opt-in to send</li>
							<li>a council + the dissent, shown</li>
							<li>built for grid-down &amp; field work</li>
							<li>free · apache-2.0 · forkable</li>
						</ul>
					</div>
				</div>
			</section>

			<!-- routing -->
			<section class="band" id="routing">
				<p class="cmd"><span class="ps1">council@usb:~$</span> {sections.routing}</p>
				<div class="split">
					<div>
						<h2>Nothing leaves the stick without your word.</h2>
						<p class="lead">Works fully offline by default. With a network it gets smarter — but every online step prints a <b>Privacy-Diff</b> first.</p>
						<ul class="ticks">
							<li>default: <span class="state state-off">offline</span> — zero upload.</li>
							<li>opt-in: <span class="state state-on">online-council</span> — frontier models, your keys.</li>
							<li>keys live passphrase-encrypted in the vault.</li>
						</ul>
					</div>
					<div class="diff reveal" role="group" aria-label="Privacy-Diff readout">
						<div class="diff-head">privacy-diff · before send</div>
						<div class="diff-row"><span>contents</span><b>logs.txt · 2.1 kB</b></div>
						<div class="diff-row"><span>providers</span><b>anthropic · openai</b></div>
						<div class="diff-row"><span>est. cost</span><b>$0.04</b></div>
						<div class="diff-row"><span>store local</span><b>yes</b></div>
						<div class="diff-actions"><button class="btn sm" type="button">[esc] cancel</button><button class="btn sm primary" type="button">[↵] send</button></div>
					</div>
				</div>
			</section>

			<!-- seats -->
			<section class="band" id="seats">
				<p class="cmd"><span class="ps1">council@usb:~$</span> {sections.seats}</p>
				<h2>Bring the best models you trust.</h2>
				<p class="lead">Swappable seats — frontier houses online, MIT/Apache families on-device.</p>
				<div class="seat-grid reveal">
					{seats.map((s) => (
						<div class="seat"><span class="seat-house">{s.house}/</span><b>{s.name}</b><span class="seat-role">{s.role}</span></div>
					))}
				</div>
			</section>

			<!-- features -->
			<section class="band" id="features">
				<p class="cmd"><span class="ps1">council@usb:~$</span> {sections.features}</p>
				<h2>Everything on the stick.</h2>
				<div class="feat-grid reveal">
					{features.map((f) => (
						<div class="feat"><span class={`state ${f.tag === 'online' ? 'state-on' : 'state-off'}`}>{f.tag}</span><b>{f.k}</b><p>{f.d}</p></div>
					))}
				</div>
			</section>

			<!-- playbooks -->
			<section class="band" id="playbooks">
				<p class="cmd"><span class="ps1">council@usb:~$</span> {sections.playbooks}</p>
				<h2>Offline playbooks for when it counts.</h2>
				<div class="play-grid reveal">
					{playbooks.map((p, i) => (
						<div class="play"><span class="play-n">{String(i + 1).padStart(2, '0')}</span><b>{p.k}</b><p>{p.d}</p></div>
					))}
				</div>
			</section>

			<!-- editions -->
			<section class="band" id="editions">
				<p class="cmd"><span class="ps1">council@usb:~$</span> {sections.editions}</p>
				<h2>Pick a tier. <span class="accent">price: $0.</span></h2>
				<div class="ed-grid reveal">
					{editions.map((e) => (
						<div class={`ed ${e.star ? 'star' : ''}`}>
							{e.star && <span class="ed-flag">deepest</span>}
							<b>{e.n}</b><span class="ed-tag">{e.tagline}</span>
							<ul>{e.m.map((x) => <li>{x}</li>)}</ul>
							<span class="ed-req">{e.req}</span>
							<a class="btn sm primary" href="/docs/start-here/quickstart/">$ quickstart</a>
						</div>
					))}
				</div>
				<p class="note">A 20 GB model off a normal stick = ~2 min just to load. The Lab tier wants an NVMe USB-SSD. We’re honest about that.</p>
			</section>

			<!-- who -->
			<section class="band" id="who">
				<p class="cmd"><span class="ps1">council@usb:~$</span> {sections.who}</p>
				<h2>Built for people who can’t just paste it into a chatbot.</h2>
				<div class="persona-grid reveal">
					{personas.map((p, i) => (
						<div class="persona"><span class="pnum">0{i + 1}</span><h3>{p.t}</h3><p>{p.d}</p></div>
					))}
				</div>
			</section>

			<!-- compare -->
			<section class="band" id="compare">
				<p class="cmd"><span class="ps1">council@usb:~$</span> {sections.compare}</p>
				<h2>Where it sits.</h2>
				<div class="table-wrap reveal">
					<table><tbody>
						{compare.map((row, r) => (
							<tr class={r === 0 ? 'thead' : ''}>{row.map((cell, c) => <td class={c === 3 ? 'ours' : ''}>{cell}</td>)}</tr>
						))}
					</tbody></table>
				</div>
			</section>

			<!-- faq -->
			<section class="band" id="faq">
				<p class="cmd"><span class="ps1">council@usb:~$</span> {sections.faq}</p>
				<h2>Straight answers.</h2>
				<div class="faq reveal">
					{faqs.map((f) => (
						<details><summary>{f.q}</summary><p>{f.a}</p></details>
					))}
				</div>
			</section>

			<!-- proof -->
			<section class="band proof" id="proof">
				<p class="cmd"><span class="ps1">council@usb:~$</span> {sections.proof}</p>
				<h2>This spec was written by a council.</h2>
				<p class="lead">v0.2 came out of a 3-stage LLM council — first opinions on Claude Opus 4.8, GPT-5.5 and Gemini 3.1 Pro, peer-reviewed, then synthesized. The corrections are in the <a href="/docs/project/changelog/">changelog</a>. Open, forkable, built in public.</p>
			</section>

			<section class="cta-final">
				<p class="ps1 big">council@usb:~$ <span class="accent">smarter --together</span><span class="cursor" aria-hidden="true"></span></p>
				<h2>Open. Offline. Auditable.</h2>
				<div class="cta-row center">
					<a class="btn primary" href={repo}>$ star --github</a>
					<a class="btn" href="/docs/">$ read --docs</a>
				</div>
			</section>
		</main>

		<footer class="foot">
			<span># usb.plan.ai — portable ai council</span>
			<span class="muted">apache-2.0 (code) · model weights keep their own license · plan.ai</span>
		</footer>

		<style>
			:root {
				--bg: #06090a; --panel: #0b1011; --panel-2: #0f1517;
				--line: #1b2422; --line-bright: #27332f;
				--green: #4dffa0; --green-hi: #8bffc4; --green-dim: #2a8f63; --green-deep: #11432f;
				--green-glow: rgba(77, 255, 160, 0.5);
				--cyan: #38d6ff; --violet: #b794ff; --amber: #ffc24b; --red: #ff5d5d;
				--ink: #d6e4dc; --ink-soft: #93a89c; --muted: #5e7269; --faint: #38463f;
				--mono: 'JetBrains Mono', ui-monospace, Menlo, monospace;
				--display: 'Space Grotesk', system-ui, sans-serif;
				--maxw: 1100px;
			}
			* { box-sizing: border-box; }
			html { scroll-behavior: smooth; }
			body {
				margin: 0; background: var(--bg); color: var(--ink);
				font-family: var(--mono); font-size: 15.5px; line-height: 1.62;
				-webkit-font-smoothing: antialiased; overflow-x: hidden;
				background-image:
					radial-gradient(120% 80% at 84% -10%, rgba(77,255,160,0.07), transparent 58%),
					radial-gradient(90% 60% at 6% 4%, rgba(56,214,255,0.045), transparent 55%);
			}
			/* CRT overlays — pure decoration, behind nothing legible, motion-gated */
			.scanlines { position: fixed; inset: 0; z-index: 60; pointer-events: none;
				background: repeating-linear-gradient(180deg, rgba(0,0,0,0) 0 2px, rgba(0,0,0,0.16) 2px 3px);
				mix-blend-mode: multiply; opacity: 0.55; animation: scan 8s linear infinite; }
			.vignette { position: fixed; inset: 0; z-index: 59; pointer-events: none;
				box-shadow: inset 0 0 200px 40px rgba(0,0,0,0.55); background: radial-gradient(120% 120% at 50% 50%, transparent 60%, rgba(0,0,0,0.35)); }
			@keyframes scan { to { background-position: 0 600px; } }
			@keyframes flicker { 0%,100%{opacity:1} 7%{opacity:.93} 9%{opacity:1} 52%{opacity:.97} 54%{opacity:1} }
			@keyframes blink { 0%,49%{opacity:1} 50%,100%{opacity:0} }
			@keyframes bootIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }
			@keyframes type { from { width: 0; } to { width: var(--tw, 30ch); } }
			@keyframes rise { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: none; } }

			main, .nav, .foot, .concept-banner, .pillars { position: relative; z-index: 1; }
			a { color: inherit; text-decoration: none; }
			:focus-visible { outline: 2px solid var(--green); outline-offset: 3px; }
			code { font-family: var(--mono); font-size: 0.92em; color: var(--green-hi); background: rgba(77,255,160,0.08); padding: 0.05em 0.32em; border-radius: 3px; }
			.accent { color: var(--green); text-shadow: 0 0 14px var(--green-glow); }
			.muted { color: var(--muted); }
			.ps1 { color: var(--green); }
			.cursor { display: inline-block; width: 9px; height: 1.05em; background: var(--green); box-shadow: 0 0 10px var(--green-glow); vertical-align: text-bottom; margin-left: 4px; animation: blink 1.1s steps(1) infinite; }

			.state { font-size: 11px; letter-spacing: 0.04em; padding: 2px 7px; border-radius: 3px; border: 1px solid; }
			.state-off { color: var(--green); border-color: rgba(77,255,160,0.4); background: rgba(77,255,160,0.07); }
			.state-on { color: var(--cyan); border-color: rgba(56,214,255,0.4); background: rgba(56,214,255,0.07); }
			.led { width: 8px; height: 8px; border-radius: 50%; display: inline-block; background: var(--green); box-shadow: 0 0 9px var(--green-glow); }

			/* NAV */
			.nav { position: sticky; top: 0; z-index: 50; display: flex; align-items: center; justify-content: space-between; padding: 13px clamp(16px,4vw,40px); background: rgba(6,9,10,0.8); backdrop-filter: blur(8px); border-bottom: 1px solid var(--line); }
			.brand { font-weight: 700; letter-spacing: -0.01em; display: flex; align-items: center; gap: 9px; }
			.brand .dot { width: 9px; height: 9px; border-radius: 50%; background: var(--green); box-shadow: 0 0 12px var(--green); animation: blink 2.4s steps(1) infinite; }
			.nav-links { display: flex; align-items: center; gap: clamp(10px,2vw,22px); }
			.nav-links a { font-size: 13px; color: var(--ink-soft); }
			.nav-links a:hover { color: var(--green); }
			.nav-links .ghost { border: 1px solid var(--line-bright); padding: 6px 12px; border-radius: 6px; color: var(--ink); }
			.nav-links .ghost:hover { border-color: var(--green); color: var(--green); }

			.concept-banner { display: block; text-align: center; padding: 8px 16px; font-size: 12.5px; color: var(--ink-soft); background: rgba(255,194,75,0.06); border-bottom: 1px solid rgba(255,194,75,0.2); }
			.concept-banner b { color: var(--amber); }

			/* HERO CRT */
			.hero { max-width: var(--maxw); margin: 0 auto; padding: clamp(34px,6vw,72px) clamp(16px,4vw,40px) clamp(20px,3vw,40px); }
			.crt { border: 1px solid var(--line-bright); border-radius: 12px; background: linear-gradient(180deg, var(--panel-2), var(--panel)); box-shadow: 0 0 0 1px rgba(77,255,160,0.05), 0 40px 90px -40px rgba(0,0,0,0.9), inset 0 0 60px rgba(77,255,160,0.03); overflow: hidden; animation: flicker 9s infinite; }
			.crt-bar { display: flex; align-items: center; gap: 12px; padding: 10px 16px; border-bottom: 1px solid var(--line); background: rgba(0,0,0,0.25); font-size: 12.5px; color: var(--ink-soft); }
			.dots { display: flex; gap: 6px; } .dots i { width: 10px; height: 10px; border-radius: 50%; background: var(--line-bright); display: block; }
			.dots i:first-child { background: var(--red); } .dots i:nth-child(2) { background: var(--amber); } .dots i:last-child { background: var(--green); }
			.crt-title { margin: 0 auto 0 4px; }
			.crt-stat { display: flex; align-items: center; gap: 7px; color: var(--green); margin-left: auto; }
			.crt-screen { padding: clamp(18px,3vw,34px); }

			.boot { list-style: none; margin: 0 0 26px; padding: 0; font-size: 13px; }
			.boot-line { display: flex; align-items: center; gap: 8px; padding: 2px 0; color: var(--ink-soft); opacity: 0; animation: bootIn .34s both; animation-delay: calc(var(--i) * 0.13s); }
			.boot-line .t { color: var(--green-dim); }
			.boot-line .msg { color: var(--ink-soft); white-space: nowrap; }
			.boot-line .dotfill { flex: 1; border-bottom: 1px dotted var(--faint); margin: 0 6px; transform: translateY(-3px); min-width: 14px; }
			.stamp { font-weight: 600; }
			.stamp.ok { color: var(--green); } .stamp.held { color: var(--amber); } .stamp.none { color: var(--muted); }

			.hero-head { margin: 26px 0 22px; }
			.kicker { color: var(--green-dim); font-size: 12.5px; margin: 0 0 14px; letter-spacing: 0.04em; }
			h1 { font-family: var(--display); font-weight: 700; font-size: clamp(46px,8vw,92px); line-height: 0.92; letter-spacing: -0.03em; margin: 0; color: var(--ink); }
			.tagline { font-family: var(--mono); font-size: clamp(14.5px,1.5vw,16.5px); color: var(--ink-soft); margin: 18px 0 0; max-width: 56ch; }
			.tagline em { color: var(--green); font-style: normal; }

			.prompt { display: flex; align-items: center; flex-wrap: wrap; gap: 8px; padding: 12px 14px; margin: 4px 0 22px; border: 1px solid var(--line); border-radius: 8px; background: rgba(0,0,0,0.25); font-size: 13.5px; }
			.prompt .typed { color: var(--green-hi); overflow: hidden; white-space: nowrap; display: inline-block; --tw: 46ch; animation: type 1.5s steps(46) 1.5s both; }
			.prompt .cursor { margin-left: 0; }

			.cta-row { display: flex; gap: 12px; flex-wrap: wrap; } .cta-row.center { justify-content: center; }
			.btn { font-family: var(--mono); font-size: 13.5px; font-weight: 500; padding: 11px 18px; border-radius: 7px; border: 1px solid var(--line-bright); background: rgba(255,255,255,0.02); color: var(--ink); cursor: pointer; transition: transform .15s, border-color .2s, box-shadow .2s, background .2s; }
			.btn:hover { transform: translateY(-2px); border-color: var(--green); color: var(--green); }
			.btn.primary { background: var(--green); color: #021109; border-color: var(--green); font-weight: 700; }
			.btn.primary:hover { color: #021109; box-shadow: 0 0 26px var(--green-glow); }
			.btn.sm { padding: 8px 12px; font-size: 12.5px; }

			/* pillars */
			.pillars { max-width: var(--maxw); margin: 0 auto; padding: 0 clamp(16px,4vw,40px) clamp(20px,3vw,40px); display: grid; grid-template-columns: repeat(3,1fr); gap: 0; border-top: 1px solid var(--line); }
			.pillar { padding: 24px clamp(14px,2vw,26px); border-right: 1px solid var(--line); }
			.pillar:last-child { border-right: none; }
			.p-tag { color: var(--green-dim); font-size: 11.5px; }
			.pillar b { display: block; margin: 10px 0 7px; color: var(--green); font-weight: 600; font-size: 16px; }
			.pillar p { margin: 0; color: var(--ink-soft); font-size: 13.5px; }

			/* bands */
			.band { max-width: var(--maxw); margin: 0 auto; padding: clamp(40px,6vw,80px) clamp(16px,4vw,40px); border-top: 1px solid var(--line); }
			.cmd { font-size: 13px; color: var(--ink-soft); margin: 0 0 22px; }
			.cmd .ps1 { margin-right: 8px; }
			h2 { font-family: var(--display); font-weight: 600; font-size: clamp(26px,4vw,44px); line-height: 1.06; letter-spacing: -0.02em; margin: 0 0 16px; max-width: 24ch; color: var(--ink); }
			.lead { font-size: clamp(15px,1.6vw,17px); color: var(--ink-soft); max-width: 64ch; margin: 0; }
			.split { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(24px,4vw,48px); align-items: center; }

			.rows { margin-top: 30px; }
			.row { display: grid; grid-template-columns: 50px 1fr; gap: 16px; padding: 20px 0; border-top: 1px solid var(--line); }
			.row:first-child { border-top: none; }
			.row-n { color: var(--green); font-size: 13px; }
			.row h3 { font-family: var(--mono); font-weight: 600; font-size: 17px; margin: 0 0 6px; color: var(--green-hi); }
			.row p { margin: 0; color: var(--ink-soft); font-size: 14.5px; }

			.ticks { list-style: none; padding: 0; margin: 20px 0 0; display: flex; flex-direction: column; gap: 12px; }
			.ticks li { padding-left: 22px; position: relative; color: var(--ink); }
			.ticks li::before { content: '▸'; position: absolute; left: 0; color: var(--green); }

			/* dossier */
			.dossier { margin: 0; border: 1px solid var(--line-bright); border-radius: 10px; overflow: hidden; background: var(--panel); font-size: 13.5px; }
			.dsr-meta { display: grid; grid-template-columns: 1fr 1fr; border-bottom: 1px solid var(--line); }
			.dsr-meta span { padding: 9px 14px; border-bottom: 1px solid var(--line); color: var(--ink-soft); font-size: 12px; }
			.dsr-meta span:nth-last-child(-n+2) { border-bottom: none; }
			.dsr-meta b { color: var(--green-dim); font-weight: 500; margin-right: 8px; } .dsr-meta .ok b { color: var(--green); }
			.dsr-log { list-style: none; margin: 0; padding: 10px 0; }
			.op { display: grid; grid-template-columns: 70px 14px 1fr; gap: 8px; padding: 5px 14px; color: var(--ink-soft); line-height: 1.5; }
			.op .r { color: var(--muted); } .op .gl { font-weight: 700; }
			.op.solver .gl { color: var(--ink-soft); }
			.op.risk .r { color: var(--amber); } .op.risk .gl { color: var(--amber); }
			.dsr-rank { padding: 9px 14px; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); color: var(--ink-soft); font-size: 12.5px; }
			.dsr-rank .r { color: var(--muted); margin-right: 8px; }
			.dsr-verdict { display: grid; grid-template-columns: 70px 14px 1fr; gap: 8px; padding: 12px 14px; background: rgba(77,255,160,0.05); color: var(--ink); }
			.dsr-verdict .r { color: var(--green); } .dsr-verdict .gl { color: var(--green); font-weight: 700; }

			/* versus */
			.versus { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 30px; }
			.vs-col { border: 1px solid var(--line); border-radius: 10px; padding: 22px; background: var(--panel); }
			.vs-col.ours { border-color: rgba(77,255,160,0.38); background: rgba(77,255,160,0.035); }
			.vs-head { font-size: 13.5px; margin-bottom: 14px; }
			.vs-col.cloud .vs-head { color: var(--red); } .vs-col.ours .vs-head { color: var(--green); }
			.vs-col ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 11px; }
			.vs-col li { font-size: 14px; padding-left: 22px; position: relative; }
			.vs-col.cloud li { color: var(--ink-soft); } .vs-col.cloud li::before { content: '✕'; position: absolute; left: 0; color: var(--red); }
			.vs-col.ours li { color: var(--ink); } .vs-col.ours li::before { content: '✓'; position: absolute; left: 0; color: var(--green); }

			.diff { border: 1px solid var(--line-bright); border-radius: 10px; overflow: hidden; background: var(--panel); }
			.diff-head { padding: 11px 14px; border-bottom: 1px solid var(--line); font-size: 12px; color: var(--cyan); }
			.diff-row { display: flex; justify-content: space-between; padding: 10px 14px; font-size: 13px; border-bottom: 1px solid var(--line); }
			.diff-row span { color: var(--muted); } .diff-row b { color: var(--ink); font-weight: 500; }
			.diff-actions { display: flex; gap: 10px; padding: 13px 14px; justify-content: flex-end; }

			.seat-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; margin-top: 30px; }
			.seat { border: 1px solid var(--line); border-radius: 9px; padding: 16px; background: var(--panel); display: flex; flex-direction: column; gap: 5px; transition: border-color .2s, transform .2s; }
			.seat:hover { border-color: var(--green); transform: translateY(-3px); }
			.seat-house { color: var(--muted); font-size: 11.5px; }
			.seat b { font-size: 15px; font-weight: 600; color: var(--ink); } .seat-role { color: var(--green); font-size: 12px; }

			.feat-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 12px; margin-top: 30px; }
			.feat { border: 1px solid var(--line); border-radius: 9px; padding: 16px; background: var(--panel); }
			.feat b { display: block; margin: 11px 0 6px; font-size: 14.5px; color: var(--green-hi); } .feat p { color: var(--ink-soft); font-size: 13px; margin: 0; }

			.play-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 12px; margin-top: 30px; }
			.play { border: 1px solid var(--line); border-radius: 9px; padding: 18px; background: var(--panel); }
			.play-n { color: var(--green); font-size: 12px; }
			.play b { display: block; margin: 8px 0 6px; font-size: 14.5px; color: var(--ink); } .play p { margin: 0; color: var(--ink-soft); font-size: 13px; }

			.ed-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; margin-top: 30px; }
			.ed { position: relative; border: 1px solid var(--line); border-radius: 11px; padding: 24px; background: var(--panel); display: flex; flex-direction: column; gap: 7px; }
			.ed.star { border-color: var(--green); box-shadow: 0 0 40px -22px var(--green-glow); }
			.ed-flag { position: absolute; top: -10px; right: 16px; font-size: 11px; color: #021109; background: var(--green); padding: 3px 9px; border-radius: 20px; font-weight: 600; }
			.ed > b { font-family: var(--display); font-size: 26px; font-weight: 600; color: var(--ink); }
			.ed-tag { color: var(--ink-soft); font-size: 13px; }
			.ed ul { list-style: none; padding: 0; margin: 8px 0; display: flex; flex-direction: column; gap: 7px; font-size: 13.5px; color: var(--ink-soft); }
			.ed ul li { padding-left: 20px; position: relative; } .ed ul li::before { content: '+'; position: absolute; left: 0; color: var(--green); }
			.ed-req { color: var(--muted); font-size: 12px; padding-top: 10px; border-top: 1px solid var(--line); margin-top: auto; }
			.ed .btn { margin-top: 12px; text-align: center; }
			.note { margin-top: 22px; color: var(--muted); font-size: 13px; }

			.persona-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; margin-top: 30px; }
			.persona { border-left: 2px solid var(--green); padding: 4px 0 4px 20px; }
			.pnum { color: var(--green); font-size: 12.5px; }
			.persona h3 { font-family: var(--mono); font-weight: 600; font-size: 16px; margin: 7px 0; color: var(--green-hi); } .persona p { color: var(--ink-soft); font-size: 14px; margin: 0; }

			.table-wrap { margin-top: 28px; overflow-x: auto; border: 1px solid var(--line); border-radius: 10px; }
			table { width: 100%; border-collapse: collapse; font-size: 13.5px; }
			td { padding: 12px 14px; border-bottom: 1px solid var(--line); border-right: 1px solid var(--line); color: var(--ink-soft); }
			tr:last-child td { border-bottom: none; } td:last-child { border-right: none; }
			.thead td { color: var(--ink); background: rgba(255,255,255,0.02); }
			td.ours { color: var(--green); background: rgba(77,255,160,0.05); }
			td:first-child { color: var(--muted); }

			.faq { margin-top: 26px; max-width: 760px; }
			details { border: 1px solid var(--line); border-radius: 9px; padding: 2px 16px; margin-bottom: 9px; background: var(--panel); }
			details[open] { border-color: var(--line-bright); }
			summary { cursor: pointer; padding: 13px 0; font-weight: 500; list-style: none; display: flex; justify-content: space-between; gap: 16px; color: var(--ink); }
			summary::-webkit-details-marker { display: none; }
			summary::after { content: '+'; color: var(--green); } details[open] summary::after { content: '−'; }
			details p { margin: 0 0 15px; color: var(--ink-soft); font-size: 14px; }

			.proof a { color: var(--green); text-decoration: underline; text-underline-offset: 3px; }

			.cta-final { max-width: var(--maxw); margin: 0 auto; padding: clamp(56px,10vw,120px) clamp(16px,4vw,40px); text-align: center; border-top: 1px solid var(--line); }
			.cta-final .ps1.big { font-size: clamp(15px,2vw,20px); margin: 0 0 18px; }
			.cta-final h2 { font-family: var(--display); font-weight: 700; font-size: clamp(30px,5vw,56px); margin: 0 auto 28px; }

			.foot { max-width: var(--maxw); margin: 0 auto; padding: 26px clamp(16px,4vw,40px); border-top: 1px solid var(--line); display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px; font-size: 12.5px; color: var(--ink-soft); }

			.reveal { opacity: 0; transform: translateY(20px); transition: opacity .7s, transform .7s; }
			.reveal.in { opacity: 1; transform: none; }

			@media (max-width: 900px) {
				.split, .versus { grid-template-columns: 1fr; }
				.pillars { grid-template-columns: 1fr; } .pillar { border-right: none; border-bottom: 1px solid var(--line); } .pillar:last-child { border-bottom: none; }
				.feat-grid, .play-grid, .seat-grid, .persona-grid, .ed-grid { grid-template-columns: 1fr 1fr; }
				.nav-links a:not(.ghost) { display: none; }
			}
			@media (max-width: 560px) {
				.feat-grid, .play-grid, .seat-grid, .persona-grid, .ed-grid { grid-template-columns: 1fr; }
				.boot-line .msg { white-space: normal; }
			}
			@media (prefers-reduced-motion: reduce) {
				* { animation: none !important; transition: none !important; scroll-behavior: auto !important; }
				.boot-line { opacity: 1; transform: none; }
				.prompt .typed { width: auto; }
				.reveal { opacity: 1; transform: none; }
				.scanlines { display: none; }
			}
		</style>

		<script is:inline>
			const io = new IntersectionObserver(
				(es) => es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } }),
				{ threshold: 0.12 }
			);
			document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
		</script>
	</body>
</html>
