---
// usb.plan.ai — landing page. Faithful Astro port of the Claude Design bundle
// "Direction B · Council Trace" (the deliberation card IS the hero), with A's
// terminal install block and a touch of C's code-rain dividers.
// Phosphor green on near-black; JetBrains Mono + Space Grotesk. The prototype's
// React "Tweaks" panel is dropped (prototyping tool, not production); its
// defaults are baked in. A11y/perf: reduced-motion gating, AA-contrast body.
// Self-contained: scoped CSS + tiny inline JS (code-rain fill + scroll reveal).
---

<!doctype html>
<html lang="en" data-scanlines="on" data-rain="on" data-headfont="display">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>usb.plan.ai — Portable AI Council</title>
		<meta name="description" content="Not one model's opinion — a council's verdict. Offline-first, auditable AI on a USB stick. Open-source, no cloud required." />
		<link rel="canonical" href="https://usb.plan.ai/" />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://usb.plan.ai/" />
		<meta property="og:site_name" content="usb.plan.ai" />
		<meta property="og:title" content="usb.plan.ai — Portable AI Council" />
		<meta property="og:description" content="Not one model's opinion — a council's verdict. Offline-first, auditable, open-source. (v0.2 concept — building in public.)" />
		<meta property="og:image" content="https://usb.plan.ai/og.png" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="usb.plan.ai — Portable AI Council" />
		<meta name="twitter:description" content="A council's verdict, not one model's opinion. Offline-first, auditable. v0.2 concept." />
		<meta name="twitter:image" content="https://usb.plan.ai/og.png" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;0,800;1,400&family=Space+Grotesk:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<!-- global texture overlays -->
		<div class="fx fx-vig" aria-hidden="true"></div>
		<div class="fx fx-scan" aria-hidden="true"></div>

		<!-- announcement -->
		<div class="announce">
			<span class="tag">v0.2 concept &amp; spec</span> — the site &amp; docs exist; the engine, council and evals aren't built yet. Building in public → <a href="/docs/project/roadmap/">roadmap</a>
		</div>

		<!-- nav -->
		<nav class="bar">
			<div class="wrap row">
				<a class="brand" href="#top">▚ usb<b>.plan.ai</b></a>
				<div class="links">
					<a href="#how">how it works</a>
					<a href="#vs">cloud vs offline</a>
					<a href="#seats">council seats</a>
					<a href="#editions">editions</a>
					<a href="/docs/">docs</a>
				</div>
				<div class="right">
					<a class="star" href="https://github.com/planailabs/usb.plan.ai">★ Star <span class="n">GitHub</span></a>
					<a class="btn btn-pri" href="https://github.com/planailabs/usb.plan.ai">Build your own</a>
				</div>
			</div>
		</nav>

		<!-- HERO -->
		<header class="hero" id="top">
			<div class="wrap grid">
				<div>
					<span class="pill"><span class="dot" aria-hidden="true"></span>Concept · Spec v0.2 · building in public</span>
					<h1>Not one model's <span class="g">opinion.</span><br />A council's verdict.</h1>
					<p class="sub">Offline-first AI on a USB stick — voice, vision, chat, and an <b>auditable council</b> of the models you trust. A single model wins at "write me an email." A council wins at "review this code, this risk — and show me the dissent."</p>
					<div class="cta">
						<a class="btn btn-pri" href="https://github.com/planailabs/usb.plan.ai">Build your own — free</a>
						<a class="btn btn-ghost" href="#how">How it works →</a>
					</div>
					<p class="meta"><b>Apache-2.0</b> · Windows · macOS · Linux · grid-down ready · no login · no telemetry</p>
				</div>

				<div>
					<div class="trace">
						<div class="th">⬡ council trace <span class="sp"><span class="dot" aria-hidden="true"></span>offline · verified</span></div>
						<div class="body">
							<div class="kv"><span class="k">prompt</span><span class="v">"run this risky bash script offline"</span></div>
							<div class="kv"><span class="k">sha256</span><span class="v nw"><span class="m">9f3a1c7b…e10d</span></span></div>
							<div class="seats">
								<span class="seat">solver</span><span class="seat">skeptic</span><span class="seat">security</span><span class="seat">chairman</span>
							</div>
							<div class="op s"><span class="role">solver›</span><span class="txt">run it with <b>sudo</b> to skip the permission errors.</span></div>
							<div class="op k"><span class="role">skeptic!</span><span class="txt"><b>sudo</b> + unverified script = full-system exposure.</span></div>
							<div class="op x"><span class="role">security!</span><span class="txt">no checksum, no sandbox. <b>block as-is.</b></span></div>
							<div class="chair">
								<div class="lbl">⬢ chairman · synthesis</div>
								<div class="ver">Don't <b>sudo</b> it. Dry-run in a sandbox, verify the checksum, run as your user.</div>
								<div class="verdict"><span class="blocked">verdict · blocked</span> → <span class="safe">safe path</span><span class="signed">signed offline · 2026-06-03</span></div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</header>

		<!-- HOW IT WORKS -->
		<section class="sec" id="how">
			<div class="rainband" data-rain-band aria-hidden="true"></div>
			<div class="wrap">
				<div class="kick reveal"><span class="no">§01</span> DELIBERATE <span class="mode">MODE · COUNCIL</span></div>
				<h2 class="h2 display reveal">A council, not a single answer.</h2>
				<p class="lead reveal">Three stages, fully local. Every opinion, the peer ranking, and the marked dissent are written to an <b>auditable trace</b> you can read, verify, and sign — offline.</p>
				<div class="steps reveal">
					<div class="step"><span class="big" aria-hidden="true">01</span><span class="n">FIRST OPINIONS</span><h3>Answer in parallel</h3><p>N seats answer independently — locally as roles, or as real frontier models on opt-in. No seat sees another's answer yet.</p></div>
					<div class="step"><span class="big" aria-hidden="true">02</span><span class="n">PEER REVIEW</span><h3>Rank the others</h3><p>Each seat ranks the others' anonymized answers. Order randomized, no self-voting. The dissent gets surfaced, not buried.</p></div>
					<div class="step"><span class="big" aria-hidden="true">03</span><span class="n">CHAIRMAN</span><h3>Synthesize a verdict</h3><p>One seat composes a reasoned final answer — plus the full trace of who said what, and where they disagreed.</p></div>
				</div>
			</div>
		</section>

		<!-- CLOUD VS OFFLINE -->
		<section class="sec" id="vs">
			<div class="wrap">
				<div class="kick reveal"><span class="no">§02</span> OFFLINE <span class="mode">GUARD · GRID-DOWN</span></div>
				<h2 class="h2 display reveal">When the grid goes down, your chatbot dies. Your council doesn't.</h2>
				<div class="vs reveal">
					<div class="vscard cloud">
						<div class="ttl">Cloud chatbot</div>
						<ul>
							<li><span class="mk">✕</span>Needs a login &amp; a live connection</li>
							<li><span class="mk">✕</span>Uploads your data to someone's server</li>
							<li><span class="mk">✕</span>One model, one opinion — trust it blindly</li>
							<li><span class="mk">✕</span>Dies the moment the grid goes down</li>
							<li><span class="mk">✕</span>Subscription, forever</li>
						</ul>
					</div>
					<div class="vscard us">
						<div class="ttl"><span class="dot" aria-hidden="true"></span>usb.plan.ai</div>
						<ul>
							<li><span class="mk">✓</span>Runs from the stick, air-gapped by default</li>
							<li><span class="mk">✓</span>Data stays local — opt-in to ever send</li>
							<li><span class="mk">✓</span>A council <b>plus the dissent</b>, shown</li>
							<li><span class="mk">✓</span>Built for grid-down &amp; field work</li>
							<li><span class="mk">✓</span>Free · Apache-2.0 · forkable</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- PRIVACY -->
		<section class="sec" id="privacy">
			<div class="rainband" data-rain-band aria-hidden="true"></div>
			<div class="wrap">
				<div class="kick reveal"><span class="no">§03</span> PRIVACY <span class="mode">GUARD · PRIVACY-DIFF</span></div>
				<div class="split">
					<div>
						<h2 class="h2 display reveal">Local-first, not local-only. Nothing leaves the stick without your word.</h2>
						<ul class="bullets reveal">
							<li><span class="b" aria-hidden="true">→</span><span><b>Default: offline</b> — zero upload, no phone-home, no account.</span></li>
							<li><span class="b" aria-hidden="true">→</span><span><b>Opt-in: online-council</b> — frontier models, your keys, gated by a Privacy-Diff.</span></li>
							<li><span class="b" aria-hidden="true">→</span><span>Keys live <b>passphrase-encrypted</b> in the on-stick vault (Argon2id + AES-256).</span></li>
							<li><span class="b" aria-hidden="true">→</span><span><b>Minimal-trace, honestly</b> — unavoidable OS artifacts are documented, not hidden.</span></li>
						</ul>
					</div>
					<div class="pdiff reveal" role="group" aria-label="Privacy-Diff before send">
						<div class="th"><span class="dot cyan" aria-hidden="true"></span>privacy-diff · before send</div>
						<div class="rows">
							<div class="r"><span class="k">contents</span><span class="v">logs.txt · 2.1 kB</span></div>
							<div class="r"><span class="k">providers</span><span class="v on">Anthropic · OpenAI</span></div>
							<div class="r"><span class="k">est. cost</span><span class="v cost">$0.04</span></div>
							<div class="r"><span class="k">store local</span><span class="v">yes — encrypted</span></div>
						</div>
						<div class="foot">
							<span class="c cancel">Cancel</span>
							<span class="c send">Send to council</span>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- COUNCIL SEATS -->
		<section class="sec" id="seats">
			<div class="wrap">
				<div class="kick reveal"><span class="no">§04</span> REGISTRY <span class="mode">SEATS · SWAPPABLE</span></div>
				<h2 class="h2 display reveal">Bring the best models you trust.</h2>
				<p class="lead reveal">Swappable seats — frontier houses online, MIT/Apache families on-device. The default bundle ships <b>redistributable weights only</b>. Defaults the community maintains.</p>
				<div class="models reveal">
					<div class="model"><div class="top"><span class="vendor">Anthropic</span><span class="tag on">online</span></div><div class="name">Claude Opus 4.8</div><div class="role">Reasoning seat</div><div class="lic">BYO key</div></div>
					<div class="model"><div class="top"><span class="vendor">OpenAI</span><span class="tag on">online</span></div><div class="name">GPT-5.5</div><div class="role">All-round seat</div><div class="lic">BYO key</div></div>
					<div class="model"><div class="top"><span class="vendor">Google</span><span class="tag on">online</span></div><div class="name">Gemini 3.1 Pro</div><div class="role">Long-context · Chairman</div><div class="lic">BYO key</div></div>
					<div class="model"><div class="top"><span class="vendor">DeepSeek</span><span class="tag off">on-device</span></div><div class="name">DeepSeek-R1-Distill 32B</div><div class="role">Reasoning · local</div><div class="lic">MIT · ~20 GB</div></div>
					<div class="model"><div class="top"><span class="vendor">Qwen</span><span class="tag off">on-device</span></div><div class="name">Qwen3-32B</div><div class="role">Agent / tools · local</div><div class="lic">Apache-2.0 · ~20 GB</div></div>
					<div class="model"><div class="top"><span class="vendor">whisper.cpp</span><span class="tag off">on-device</span></div><div class="name">whisper · large-v3-turbo</div><div class="role">Voice (STT) · local</div><div class="lic">MIT · ~1.5 GB</div></div>
				</div>
			</div>
		</section>

		<!-- INSIDE THE APP -->
		<section class="sec" id="app">
			<div class="rainband" data-rain-band aria-hidden="true"></div>
			<div class="wrap">
				<div class="kick reveal"><span class="no">§05</span> SURFACE <span class="mode">APP · BROWSER-ONLY</span></div>
				<h2 class="h2 display reveal">Everything on the stick.</h2>
				<p class="lead reveal">A browser-only UI served at <span class="g">localhost:4321</span> — nothing to install on the host.</p>
				<div class="feats reveal">
					<div class="feat"><span class="tag off">offline</span><h3>Local Chat</h3><p>Fast single-model answers — the default mode.</p></div>
					<div class="feat"><span class="tag off">offline</span><h3>Council / Review</h3><p>Solve → Skeptic → Synthesis. The deliberate deep mode.</p></div>
					<div class="feat"><span class="tag off">offline</span><h3>Council Trace</h3><p>Every opinion, the peer ranking, the marked dissent.</p></div>
					<div class="feat"><span class="tag off">offline</span><h3>Voice (STT)</h3><p>Push-to-talk, on-device whisper.cpp.</p></div>
					<div class="feat"><span class="tag off">offline</span><h3>Vision (VLM)</h3><p>Read images and documents locally.</p></div>
					<div class="feat"><span class="tag off">offline</span><h3>Phone Access</h3><p>A 2nd screen on your LAN — TLS + one-time token.</p></div>
					<div class="feat"><span class="tag on">online</span><h3>BYO API Keys</h3><p>Passphrase-encrypted in the on-stick vault.</p></div>
					<div class="feat"><span class="tag on">online</span><h3>Privacy-Diff</h3><p>See exactly what is sent, to whom, at what cost.</p></div>
				</div>
			</div>
		</section>

		<!-- EDITIONS + INSTALL -->
		<section class="sec" id="editions">
			<div class="wrap">
				<div class="kick reveal"><span class="no">§06</span> BUILD <span class="mode">TIERS · PRICE $0</span></div>
				<h2 class="h2 display reveal">Pick a tier. Price: $0.</h2>
				<p class="lead reveal">Open-source, Apache-2.0. Run <span class="g">preflight-check</span> first — it measures your hardware and recommends one.</p>
				<div class="tiers reveal">
					<div class="tier">
						<div class="nm">Pocket</div>
						<div class="desc">Runs almost anywhere</div>
						<ul><li><span class="b" aria-hidden="true">›</span>1× 4–8B model</li><li><span class="b" aria-hidden="true">›</span>role council</li><li><span class="b" aria-hidden="true">›</span>whisper-base voice</li></ul>
						<div class="hw">8–12 GB RAM · CPU ok · 16–32 GB stick</div>
						<a class="go" href="/docs/start-here/quickstart/">Quickstart →</a>
					</div>
					<div class="tier">
						<div class="nm">Field</div>
						<div class="desc">Documents &amp; notes, offline</div>
						<ul><li><span class="b" aria-hidden="true">›</span>8B model</li><li><span class="b" aria-hidden="true">›</span>vision (VLM)</li><li><span class="b" aria-hidden="true">›</span>voice</li></ul>
						<div class="hw">12–16 GB RAM · GPU recommended · 32 GB stick</div>
						<a class="go" href="/docs/start-here/quickstart/">Quickstart →</a>
					</div>
					<div class="tier best">
						<span class="badge">deepest</span>
						<div class="nm">Lab</div>
						<div class="desc">The real multi-model council</div>
						<ul><li><span class="b" aria-hidden="true">›</span>32B reasoning + 32B agent</li><li><span class="b" aria-hidden="true">›</span>8B + vision</li><li><span class="b" aria-hidden="true">›</span>deep deliberation</li></ul>
						<div class="hw">48–64 GB RAM · GPU · NVMe USB-SSD</div>
						<a class="go" href="/docs/start-here/quickstart/">Quickstart →</a>
					</div>
				</div>

				<div class="terminal reveal">
					<div class="bar"><span class="d r" aria-hidden="true"></span><span class="d y" aria-hidden="true"></span><span class="d g" aria-hidden="true"></span><span class="t">root@usb.plan.ai — quickstart</span></div>
					<div class="scr">
						<div class="ln"><span class="p">$</span> <span class="cmd">git clone github.com/planailabs/usb.plan.ai</span></div>
						<div class="ln out"><span class="ok">✓</span> cloned → unzip the release onto your <span class="hl">exFAT</span> drive</div>
						<div class="ln"><span class="p">$</span> <span class="cmd">./preflight-check</span></div>
						<div class="ln out"><span class="ok">[ ok ]</span> filesystem exFAT · USB 3.2 read 980 MB/s · RAM 64 GB · GPU detected</div>
						<div class="ln out"><span class="ok">[ ok ]</span> recommended tier → <span class="hl">Lab</span> (32B×2 + 8B + vision)</div>
						<div class="ln"><span class="p">$</span> <span class="cmd">./install --tier lab</span></div>
						<div class="ln out"><span class="ok">✓</span> model-packs verified (license + sha-256) · vault sealed</div>
						<div class="ln"><span class="p">$</span> <span class="cmd">./start-linux.sh</span> <span class="hl"># → http://localhost:4321</span><span class="cursor" aria-hidden="true"></span></div>
					</div>
				</div>
			</div>
		</section>

		<!-- COMPARE -->
		<section class="sec tight" id="compare">
			<div class="wrap">
				<div class="kick reveal"><span class="no">§07</span> COMPARE <span class="mode">INDEX · WHERE IT SITS</span></div>
				<h2 class="h2 display reveal">Where it sits.</h2>
				<table class="ctable reveal">
					<thead><tr><th></th><th>PortableMind</th><th>techjarves</th><th class="us">usb.plan.ai</th></tr></thead>
					<tbody>
						<tr><td>License</td><td class="muted">Closed</td><td>MIT</td><td class="us yes">Apache-2.0</td></tr>
						<tr><td>Core</td><td class="muted">Single-model</td><td class="muted">Single-model</td><td class="us yes">Auditable council</td></tr>
						<tr><td>Council mode</td><td class="muted">—</td><td class="muted">—</td><td class="us yes">Opinion · Review · Chairman</td></tr>
						<tr><td>Online (opt-in)</td><td class="muted">—</td><td class="muted">—</td><td class="us yes">Frontier + Privacy-Diff</td></tr>
						<tr><td>Engine</td><td class="muted">Proprietary</td><td>Ollama</td><td class="us">llama.cpp llama-server</td></tr>
						<tr><td>Price</td><td class="muted">$49–$129</td><td>Free</td><td class="us yes">Free (OSS)</td></tr>
					</tbody>
				</table>
			</div>
		</section>

		<!-- FAQ -->
		<section class="sec tight" id="faq">
			<div class="rainband" data-rain-band aria-hidden="true"></div>
			<div class="wrap">
				<div class="kick reveal"><span class="no">§08</span> FAQ <span class="mode">LOG · STRAIGHT ANSWERS</span></div>
				<h2 class="h2 display reveal">Straight answers.</h2>
				<div class="faq reveal">
					<div class="q"><div class="qt"><span class="mk" aria-hidden="true">?</span>Does it really work fully offline?</div><div class="a">Yes — that's the default. Online is opt-in only and gated by a Privacy-Diff. <b>Nothing leaves the stick without your explicit consent.</b></div></div>
					<div class="q"><div class="qt"><span class="mk" aria-hidden="true">?</span>Is there a subscription?</div><div class="a">No. It's free and open-source (Apache-2.0). Bring your own API keys if you ever want to escalate online.</div></div>
					<div class="q"><div class="qt"><span class="mk" aria-hidden="true">?</span>What hardware do I need?</div><div class="a">Pocket runs on a normal laptop (8–12 GB RAM, CPU ok). The multi-model Lab tier wants <b>48–64 GB RAM, a GPU, and an NVMe USB-SSD</b>.</div></div>
					<div class="q"><div class="qt"><span class="mk" aria-hidden="true">?</span>Council vs a single model — when does it win?</div><div class="a">"Review this code / decision / risk and show me the dissent." For "write me an email," a single model is fine. <b>The edge is measured in evals, not asserted.</b></div></div>
					<div class="q"><div class="qt"><span class="mk" aria-hidden="true">?</span>Is it "zero trace"?</div><div class="a">No — minimal-trace, honestly. No persistent user data on the host, but unavoidable OS artifacts exist and are documented. A compromised host is out of scope.</div></div>
				</div>
			</div>
		</section>

		<!-- FINAL CTA -->
		<section class="final">
			<div class="rainband" data-rain-band aria-hidden="true"></div>
			<div class="wrap">
				<h2 class="display">Open. Offline. Auditable.<br /><span class="g">Smarter together.</span></h2>
				<div class="cta">
					<a class="btn btn-pri" href="https://github.com/planailabs/usb.plan.ai">★ Star on GitHub</a>
					<a class="btn btn-ghost" href="/docs/">Read the docs →</a>
				</div>
			</div>
		</section>

		<footer>
			<div class="wrap row">
				<span class="brand">▚ usb<b>.plan.ai</b></span>
				<span style="color:var(--muted)">Portable AI Council</span>
				<span class="sp"></span>
				<span style="color:var(--green-dim)">Apache-2.0 (code)</span>
				<span style="color:var(--muted)">· model weights keep their own license · plan.ai</span>
			</div>
		</footer>

		<style>
			/* ===== tokens ===== */
			:root {
				--bg: #06090a; --panel: #0b1011; --panel-2: #0f1517;
				--line: #1b2422; --line-bright: #27332f;
				--green: #4dffa0; --green-hi: #8bffc4; --green-dim: #2a8f63; --green-deep: #11432f;
				--green-glow: rgba(77,255,160,0.55);
				--cyan: #38d6ff; --amber: #ffc24b; --red: #ff5d5d; --violet: #b794ff;
				--ink: #d6e4dc; --ink-soft: #93a89c; --muted: #5e7269; --faint: #38463f;
				--mono: 'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace;
				--display: 'Space Grotesk', system-ui, sans-serif;
				--maxw: 1180px;
			}
			* { box-sizing: border-box; }
			::selection { background: var(--green); color: #04110a; }
			html { scroll-behavior: smooth; }
			body { margin: 0; background: var(--bg); color: var(--ink); font-family: var(--mono); font-size: 15px; line-height: 1.6; -webkit-font-smoothing: antialiased; }
			a { color: inherit; text-decoration: none; }
			h1, h2, h3 { margin: 0; font-weight: 700; }
			p { margin: 0; }
			:focus-visible { outline: 2px solid var(--green); outline-offset: 3px; }

			/* texture overlays */
			.fx { position: fixed; inset: 0; pointer-events: none; z-index: 200; }
			html[data-scanlines="off"] .fx-scan { display: none; }
			.fx-scan { background: repeating-linear-gradient(to bottom, rgba(0,0,0,0) 0 2px, rgba(0,0,0,0.13) 2px 3px); mix-blend-mode: multiply; opacity: 0.8; }
			.fx-vig { background: radial-gradient(130% 100% at 50% -10%, transparent 60%, rgba(0,0,0,0.5) 100%); }
			html[data-headfont="mono"] .display { font-family: var(--mono); letter-spacing: -0.01em; font-weight: 800; }

			/* layout */
			.wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 32px; }
			.display { font-family: var(--display); }
			.sec { position: relative; padding: 104px 0; border-top: 1px solid var(--line); }
			.sec.tight { padding: 80px 0; }
			.rainband { position: absolute; inset: 0; overflow: hidden; pointer-events: none; z-index: 0; opacity: 0.06; color: var(--green); font-family: var(--mono); font-size: 12px; line-height: 1.4; letter-spacing: 2px; white-space: pre; -webkit-mask-image: linear-gradient(180deg, #000, transparent 40%); mask-image: linear-gradient(180deg, #000, transparent 40%); }
			html[data-rain="off"] .rainband { display: none; }
			.sec > .wrap, .final > .wrap { position: relative; z-index: 1; }

			.kick { display: flex; align-items: center; gap: 14px; font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--green-dim); margin-bottom: 20px; }
			.kick .no { color: var(--green); }
			.kick .mode { margin-left: auto; color: var(--muted); border: 1px solid var(--line-bright); border-radius: 3px; padding: 4px 9px; letter-spacing: 0.12em; }
			.h2 { font-size: 42px; line-height: 1.06; letter-spacing: -0.025em; max-width: 20ch; color: var(--ink); }
			.lead { margin-top: 18px; font-size: 16.5px; line-height: 1.6; color: var(--ink-soft); max-width: 56ch; }
			.lead b { color: var(--ink); font-weight: 500; }
			.g { color: var(--green); }

			/* buttons / pills */
			.pill { display:inline-flex; align-items:center; gap:9px; font-size:12px; letter-spacing:0.12em; text-transform:uppercase; color: var(--green); border:1px solid var(--green-deep); background: rgba(77,255,160,0.05); padding:7px 13px; border-radius:999px; white-space:nowrap; }
			.dot { width:7px; height:7px; border-radius:50%; background: var(--green); box-shadow:0 0 9px var(--green-glow); display:inline-block; }
			.dot.cyan { background: var(--cyan); box-shadow: 0 0 9px var(--cyan); }
			.btn { display:inline-flex; align-items:center; gap:10px; white-space:nowrap; font-size:15px; padding:13px 20px; border-radius:4px; cursor:pointer; transition: all .15s ease; font-family: var(--mono); }
			.btn-pri { background: var(--green); color:#04130b; font-weight:700; box-shadow: 0 0 26px rgba(77,255,160,0.25); border: 1px solid var(--green); }
			.btn-pri:hover { background: var(--green-hi); border-color: var(--green-hi); box-shadow: 0 0 34px rgba(77,255,160,0.4); }
			.btn-ghost { color: var(--ink); border:1px solid var(--line-bright); }
			.btn-ghost:hover { border-color: var(--green-dim); color: var(--green); }

			/* announce + nav */
			.announce { background: rgba(77,255,160,0.05); border-bottom: 1px solid var(--line); font-size: 12.5px; color: var(--ink-soft); text-align:center; padding: 9px 16px; letter-spacing:0.02em; }
			.announce a { color: var(--green); } .announce a:hover { text-decoration: underline; }
			.announce .tag { color: var(--green); font-weight: 700; }
			nav.bar { position: sticky; top: 0; z-index: 100; backdrop-filter: blur(10px); background: rgba(6,9,10,0.78); border-bottom: 1px solid var(--line); }
			nav.bar .row { display:flex; align-items:center; gap: 26px; height: 60px; }
			nav.bar .brand { color: var(--green); font-weight: 700; font-size: 15px; letter-spacing: 0.02em; }
			nav.bar .brand b { color: var(--ink); }
			nav.bar .links { display:flex; gap: 24px; font-size: 13.5px; color: var(--muted); }
			nav.bar .links a:hover { color: var(--green); }
			nav.bar .right { margin-left:auto; display:flex; align-items:center; gap:12px; }
			nav.bar .star { display:flex; align-items:center; gap:8px; font-size:13px; color: var(--ink-soft); border:1px solid var(--line-bright); padding:8px 12px; border-radius:4px; }
			nav.bar .star:hover { border-color: var(--green-dim); color: var(--green); }
			nav.bar .star .n { color: var(--muted); border-left:1px solid var(--line-bright); padding-left:8px; }

			/* HERO */
			.hero { position: relative; padding: 70px 0 92px; overflow: hidden; }
			.hero .grid { display:grid; grid-template-columns: 1.05fr 1fr; gap: 56px; align-items: center; }
			.hero h1 { font-family: var(--display); font-size: 60px; line-height: 1.0; letter-spacing: -0.03em; margin-top: 22px; color: var(--ink); }
			.hero h1 .g { color: var(--green); text-shadow: 0 0 28px var(--green-glow); }
			.hero .sub { margin-top: 24px; font-size: 17px; line-height: 1.62; color: var(--ink-soft); max-width: 48ch; }
			.hero .sub b { color: var(--ink); font-weight: 500; }
			.hero .cta { margin-top: 32px; display:flex; gap: 14px; align-items:center; flex-wrap: wrap; }
			.hero .meta { margin-top: 30px; font-size: 12.5px; color: var(--muted); letter-spacing: 0.03em; }
			.hero .meta b { color: var(--green-dim); }

			/* trace card */
			.trace { background: linear-gradient(180deg,#0c1213,#090d0e); border:1px solid var(--line-bright); border-radius:10px; overflow:hidden; box-shadow: 0 40px 90px -40px #000, 0 0 0 1px rgba(77,255,160,0.04); }
			.trace .th { display:flex; align-items:center; gap:10px; padding: 13px 16px; border-bottom:1px solid var(--line); font-size:11.5px; letter-spacing:0.14em; text-transform:uppercase; color: var(--ink-soft); }
			.trace .th .sp { margin-left:auto; color: var(--green); font-size:11px; display:flex; align-items:center; gap:7px; }
			.trace .body { padding: 16px 18px; }
			.kv { display:flex; gap:10px; font-size:12.5px; margin-bottom:11px; align-items:flex-start; }
			.kv .k { color: var(--muted); width:62px; flex:none; }
			.kv .v { color: var(--ink-soft); } .kv .v.nw { white-space:nowrap; } .kv .v .m { color: var(--green-dim); }
			.seats { display:flex; flex-wrap:wrap; gap:7px; margin: 8px 0 4px; }
			.seat { font-size:11px; padding:4px 9px; border-radius:3px; border:1px solid var(--line-bright); color: var(--ink-soft); }
			.op { display:flex; gap:11px; padding:11px 0; border-top:1px solid var(--line); font-size:13px; line-height:1.45; }
			.op .role { flex:none; width:80px; font-weight:700; }
			.op.s .role { color: var(--green); } .op.k .role { color: var(--amber); } .op.x .role { color: var(--red); }
			.op .txt { color: var(--ink-soft); } .op .txt b { color: var(--ink); font-weight:500; }
			.chair { margin-top: 14px; padding:14px; border:1px solid var(--green-deep); background: rgba(77,255,160,0.05); border-radius:6px; }
			.chair .lbl { color: var(--violet); font-size:11px; letter-spacing:0.12em; text-transform:uppercase; margin-bottom:7px; }
			.chair .ver { color: var(--ink); font-size:13.5px; line-height:1.5; } .chair .ver b { color: var(--green); }
			.verdict { display:flex; align-items:center; gap:10px; margin-top:13px; padding-top:13px; border-top:1px solid var(--line); font-size:11.5px; }
			.verdict .blocked { color: var(--red); } .verdict .safe { color: var(--green); } .verdict .signed { margin-left:auto; color: var(--muted); }

			/* steps */
			.steps { display:grid; grid-template-columns: repeat(3,1fr); gap: 1px; margin-top: 52px; background: var(--line); border:1px solid var(--line); border-radius: 10px; overflow:hidden; }
			.step { background: var(--panel); padding: 32px 28px; position: relative; }
			.step .n { font-family: var(--mono); font-size: 13px; color: var(--green); letter-spacing: 0.1em; }
			.step h3 { font-family: var(--display); font-size: 22px; margin-top: 14px; color: var(--ink); }
			.step p { margin-top: 10px; color: var(--ink-soft); font-size: 14px; line-height: 1.6; }
			.step .big { position:absolute; right: 20px; top: 14px; font-family: var(--display); font-weight:700; font-size: 60px; color: var(--green); opacity: 0.07; line-height: 1; }

			/* cloud vs offline */
			.vs { display:grid; grid-template-columns: 1fr 1fr; gap: 22px; margin-top: 48px; }
			.vscard { border:1px solid var(--line-bright); border-radius:10px; padding: 26px 26px 28px; background: var(--panel); }
			.vscard.cloud { opacity: 0.92; }
			.vscard.us { border-color: var(--green-deep); background: linear-gradient(180deg, rgba(77,255,160,0.045), var(--panel)); box-shadow: 0 0 40px -18px var(--green-glow); }
			.vscard .ttl { display:flex; align-items:center; gap:10px; font-size: 14px; letter-spacing:0.05em; color: var(--ink); padding-bottom: 18px; border-bottom:1px solid var(--line); }
			.vscard.cloud .ttl { color: var(--ink-soft); }
			.vscard ul { list-style:none; margin: 18px 0 0; padding:0; display:flex; flex-direction:column; gap: 13px; }
			.vscard li { display:flex; gap: 12px; font-size: 14.5px; color: var(--ink-soft); line-height:1.45; }
			.vscard li .mk { flex:none; width: 18px; font-weight: 700; }
			.vscard.cloud li .mk { color: var(--red); } .vscard.us li .mk { color: var(--green); } .vscard.us li { color: var(--ink); }

			/* privacy diff */
			.split { display:grid; grid-template-columns: 1fr 0.85fr; gap: 56px; align-items:center; margin-top: 44px; }
			.bullets { list-style:none; margin: 22px 0 0; padding:0; display:flex; flex-direction:column; gap: 14px; }
			.bullets li { display:flex; gap: 12px; font-size: 15px; color: var(--ink-soft); }
			.bullets li .b { color: var(--green); flex:none; } .bullets li b { color: var(--ink); font-weight: 500; }
			.pdiff { background: linear-gradient(180deg,#0c1213,#090d0e); border:1px solid var(--line-bright); border-radius:10px; overflow:hidden; box-shadow: 0 30px 70px -36px #000; }
			.pdiff .th { padding: 13px 16px; border-bottom:1px solid var(--line); font-size:11.5px; letter-spacing:0.14em; text-transform:uppercase; color: var(--cyan); display:flex; align-items:center; gap:8px; }
			.pdiff .rows { padding: 8px 18px; }
			.pdiff .r { display:flex; align-items:center; padding: 11px 0; border-bottom:1px dashed var(--line); font-size:13.5px; }
			.pdiff .r:last-child { border-bottom:none; }
			.pdiff .r .k { color: var(--muted); width: 110px; flex:none; }
			.pdiff .r .v { color: var(--ink); } .pdiff .r .v.on { color: var(--cyan); } .pdiff .r .v.cost { color: var(--green); }
			.pdiff .foot { display:flex; gap: 10px; padding: 14px 18px; border-top:1px solid var(--line); }
			.pdiff .foot .c { flex:1; text-align:center; padding: 10px; border-radius:4px; font-size:13.5px; }
			.pdiff .foot .cancel { border:1px solid var(--line-bright); color: var(--ink-soft); }
			.pdiff .foot .send { background: var(--cyan); color:#04130b; font-weight:700; }

			/* model seats */
			.models { display:grid; grid-template-columns: repeat(3,1fr); gap: 14px; margin-top: 44px; }
			.model { border:1px solid var(--line-bright); border-radius:8px; padding: 18px; background: var(--panel); transition: border-color .15s; }
			.model:hover { border-color: var(--green-dim); }
			.model .top { display:flex; align-items:center; justify-content:space-between; }
			.model .vendor { font-size: 11.5px; color: var(--muted); letter-spacing:0.06em; }
			.model .tag { font-size:10.5px; padding:3px 8px; border-radius:999px; letter-spacing:0.08em; text-transform:uppercase; }
			.model .tag.on { color: var(--cyan); border:1px solid rgba(56,214,255,0.3); }
			.model .tag.off { color: var(--green); border:1px solid var(--green-deep); }
			.model .name { font-size: 17px; color: var(--ink); margin-top: 12px; font-weight: 500; }
			.model .role { font-size: 13px; color: var(--ink-soft); margin-top: 5px; }
			.model .lic { font-size: 11px; color: var(--green-dim); margin-top: 14px; letter-spacing:0.04em; }

			/* features */
			.feats { display:grid; grid-template-columns: repeat(4,1fr); gap: 1px; margin-top: 44px; background: var(--line); border:1px solid var(--line); border-radius:10px; overflow:hidden; }
			.feat { background: var(--panel); padding: 22px 20px 24px; }
			.feat .tag { font-size:10px; letter-spacing:0.1em; text-transform:uppercase; }
			.feat .tag.off { color: var(--green); } .feat .tag.on { color: var(--cyan); }
			.feat h3 { font-size: 15.5px; color: var(--ink); margin-top: 10px; font-weight: 600; font-family: var(--mono); }
			.feat p { font-size: 12.5px; color: var(--ink-soft); margin-top: 7px; line-height:1.5; }

			/* editions */
			.tiers { display:grid; grid-template-columns: repeat(3,1fr); gap: 16px; margin-top: 44px; }
			.tier { border:1px solid var(--line-bright); border-radius:10px; padding: 26px 24px; background: var(--panel); position:relative; }
			.tier.best { border-color: var(--green-deep); background: linear-gradient(180deg, rgba(77,255,160,0.05), var(--panel)); box-shadow: 0 0 44px -20px var(--green-glow); }
			.tier .badge { position:absolute; top:-10px; right: 18px; font-size:10.5px; letter-spacing:0.12em; text-transform:uppercase; background: var(--green); color:#04130b; padding:4px 10px; border-radius:999px; font-weight:700; }
			.tier .nm { font-family: var(--display); font-size: 24px; color: var(--ink); }
			.tier .desc { font-size: 13px; color: var(--ink-soft); margin-top: 5px; }
			.tier ul { list-style:none; margin: 20px 0; padding:0; display:flex; flex-direction:column; gap: 10px; }
			.tier li { font-size: 14px; color: var(--ink-soft); display:flex; gap:10px; } .tier li .b { color: var(--green); }
			.tier .hw { font-size: 12px; color: var(--muted); padding-top: 16px; border-top:1px solid var(--line); }
			.tier .go { margin-top: 16px; display:inline-flex; gap:7px; color: var(--green); font-size: 14px; } .tier .go:hover { color: var(--green-hi); }

			/* terminal install */
			.terminal { margin-top: 40px; background: #090d0e; border:1px solid var(--line-bright); border-radius:10px; overflow:hidden; box-shadow: 0 30px 70px -40px #000; }
			.terminal .bar { display:flex; align-items:center; gap:8px; padding: 11px 15px; border-bottom:1px solid var(--line); }
			.terminal .bar .d { width:11px; height:11px; border-radius:50%; }
			.terminal .bar .d.r{background:#ff5f57;} .terminal .bar .d.y{background:#febc2e;} .terminal .bar .d.g{background:#28c840;}
			.terminal .bar .t { margin-left: 10px; font-size: 12px; color: var(--muted); }
			.terminal .scr { padding: 20px 22px; font-size: 13.5px; line-height: 1.85; }
			.terminal .ln .p { color: var(--green); } .terminal .ln .cmd { color: var(--ink); }
			.terminal .ln.out { color: var(--muted); } .terminal .ln.out .ok { color: var(--green-dim); } .terminal .ln.out .hl { color: var(--ink-soft); }
			.terminal .cursor { display:inline-block; width:0.6em; height:1.05em; background: var(--green); vertical-align: -2px; animation: blink 1.1s steps(1) infinite; }
			@keyframes blink { 50% { opacity: 0; } }

			/* compare */
			.ctable { margin-top: 40px; width:100%; border-collapse: collapse; font-size: 14px; }
			.ctable th, .ctable td { text-align:left; padding: 15px 18px; border-bottom:1px solid var(--line); }
			.ctable thead th { color: var(--muted); font-weight: 500; font-size: 12px; letter-spacing:0.08em; text-transform:uppercase; }
			.ctable thead th.us { color: var(--green); }
			.ctable td:first-child { color: var(--ink-soft); }
			.ctable td.us { color: var(--ink); background: rgba(77,255,160,0.035); border-left:1px solid var(--green-deep); border-right:1px solid var(--green-deep); }
			.ctable tbody tr:last-child td { border-bottom: none; }
			.ctable .muted { color: var(--faint); } .ctable .yes { color: var(--green); }

			/* FAQ */
			.faq { margin-top: 40px; border-top:1px solid var(--line); }
			.faq .q { border-bottom:1px solid var(--line); padding: 22px 0; }
			.faq .q .qt { display:flex; gap: 14px; font-size: 16px; color: var(--ink); }
			.faq .q .qt .mk { color: var(--green); flex:none; }
			.faq .q .a { margin-top: 10px; padding-left: 28px; color: var(--ink-soft); font-size: 14.5px; line-height: 1.6; max-width: 76ch; }
			.faq .q .a b { color: var(--ink); font-weight:500; }

			/* final */
			.final { text-align:center; padding: 110px 0; position: relative; overflow:hidden; border-top:1px solid var(--line); }
			.final h2 { font-family: var(--display); font-size: 50px; letter-spacing: -0.03em; line-height: 1.05; color: var(--ink); }
			.final h2 .g { color: var(--green); text-shadow: 0 0 30px var(--green-glow); }
			.final .cta { margin-top: 34px; display:flex; gap: 14px; justify-content:center; }

			/* footer */
			footer { border-top:1px solid var(--line); padding: 40px 0; }
			footer .row { display:flex; align-items:center; gap: 18px; font-size: 13px; color: var(--muted); flex-wrap: wrap; }
			footer .brand { color: var(--green); font-weight:700; } footer .brand b { color: var(--ink-soft); }
			footer .sp { margin-left:auto; } footer a:hover { color: var(--green); }

			/* scroll reveal — motion only when allowed */
			@media (prefers-reduced-motion: no-preference) {
				.reveal { opacity: 0; transform: translateY(18px); transition: opacity .6s ease, transform .6s ease; }
				.reveal.in { opacity: 1; transform: none; }
			}
			@media (prefers-reduced-motion: reduce) {
				.fx-scan { display: none; }
				.terminal .cursor { animation: none; }
			}

			/* responsive */
			@media (max-width: 920px) {
				.hero .grid, .split { grid-template-columns: 1fr; gap: 36px; }
				.steps, .models, .feats, .tiers, .vs { grid-template-columns: 1fr; }
				.feats { grid-template-columns: 1fr 1fr; }
				.h2 { font-size: 32px; } .hero h1 { font-size: 42px; }
				.kick .mode { display:none; }
				nav.bar .links { display:none; }
			}
		</style>

		<script is:inline>
			(function () {
				var cols = 130, rows = 12;
				document.querySelectorAll('[data-rain-band]').forEach(function (b) {
					var t = '';
					for (var r = 0; r < rows; r++) {
						var line = '';
						for (var c = 0; c < cols; c++) line += (((r * 7 + c * 13) % 5) < 2 ? '0' : '1');
						t += line + '\n';
					}
					b.textContent = t;
				});
				if (window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
					var io = new IntersectionObserver(function (es) {
						es.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
					}, { threshold: 0.12 });
					document.querySelectorAll('.reveal').forEach(function (el) { io.observe(el); });
				} else {
					document.querySelectorAll('.reveal').forEach(function (el) { el.classList.add('in'); });
				}
			})();
		</script>
	</body>
</html>
