{
  "name": "usb.plan.ai",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "dev": "concurrently -n app,docs -c blue,magenta \"pnpm dev:app\" \"pnpm dev:docs\"",
    "dev:app": "astro dev",
    "dev:docs": "pnpm --filter usb-docs dev",
    "build": "pnpm build:docs && pnpm build:app",
    "build:app": "astro build",
    "build:docs": "pnpm --filter usb-docs build && rm -rf public/docs && cp -R starlight/dist public/docs",
    "preview": "astro preview",
    "check": "pnpm check:docs && pnpm check:app",
    "check:app": "astro check",
    "check:docs": "pnpm --filter usb-docs check",
    "astro": "astro",
    "icons": "node scripts/gen-icons.mjs"
  },
  "dependencies": {
    "astro": "^6.3.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@resvg/resvg-js": "^2.6.2",
    "concurrently": "^9.1.0",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.6.3"
  }
}
